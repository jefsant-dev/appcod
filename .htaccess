RewriteEngine On

# Remove .html/.php da URL (redirecionamento canônico)
RewriteCond %{THE_REQUEST} \s/+(.+?)\.(html|php)(?:[?\s]|$) [NC]
RewriteRule ^ %1 [R=301,L]

# Não reescrever arquivos/pastas reais
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Resolve URL sem extensão para .php (prioridade)
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.+?)/?$ $1.php [L]

# Resolve URL sem extensão para .html
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+?)/?$ $1.html [L]
